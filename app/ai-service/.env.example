# Soter AI Service Environment Variables
# Copy this file to .env and fill in your actual values

# API Keys (at least one is required for AI features)
OPENAI_API_KEY=your_openai_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# Application Settings
APP_ENV=development
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000

# Redis Configuration (for Celery task queue)
# Format: redis://[username]:[password]@[host]:[port]/[database]
REDIS_URL=redis://localhost:6379/0

# Backend Webhook URL (for notifying NestJS backend of task completion)
# Default: http://localhost:3001/ai/webhook
BACKEND_WEBHOOK_URL=http://localhost:3001/ai/webhook

# Proof-of-life defaults
# Confidence threshold range: 0.0 to 1.0
PROOF_OF_LIFE_CONFIDENCE_THRESHOLD=0.65
# Minimum face bounding-box size in pixels for detection
PROOF_OF_LIFE_MIN_FACE_SIZE=80
